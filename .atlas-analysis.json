  "keyFeatures": [
    "Three store types — base (local state), derived (computed), and query (async data) — that form a composed reactive graph",
    "Runtime dependency tracking via a `$` accessor that subscribes stores to only the state they read",
    "Lazy evaluation: stores only compute and subscribe when observed; automatically clean up when unused",
    "Built-in persistence with sync and async storage adapters (localStorage, MMKV, Chrome storage)",
    "Cross-tab and cross-context sync engine with conflict resolution and session-aware metadata",
    "React and React Native support: stores double as callable React hooks in the React build",
    "Vanilla (no-React) build available via the `vanilla` package condition",
    "Chrome Extension plugin with `ChromeStorageAdapter` and `ChromeExtensionSyncEngine`",
    "Type-safe query parameters with automatic query-key generation and reactive refetching",
    "Virtual stores that rebind subscriptions when the underlying store instance changes"
  ],
  "publicApiSurface": [
    "createBaseStore(createState, options?)",
    "createDerivedStore(deriveFunction, optionsOrEqualityFn?)",
    "createQueryStore(config, stateCreatorOrOptions?, options?)",
    "createVirtualStore(createStore, overridesOrOptions?, options?)",
    "configureStores(config)",
    "createStoreActions(store, bundledMethods?)",
    "useListen(store, selector, react, optionsOrEqualityFn?)",
    "useStableValue(init)",
    "destroyStore(store, options?)",
    "destroyStores(stores, options?)",
    "getStoreName(store)",
